<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Brass: Lancashire - Login</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/" class="nav-brand">Brass: Lancashire</a>
    <div class="nav-links">
      <a href="/wiki" class="nav-link">Wiki</a>
    </div>
  </nav>
  <main class="container">
    <div class="auth-form">
      <% if (setupMode) { %>
        <h2>Welcome, <%= setupUser %>!</h2>
        <p class="muted">Set your password to get started.</p>
        <% if (error) { %><div class="error"><%= error %></div><% } %>
        <form method="POST" action="/setup-password">
          <input type="hidden" name="username" value="<%= setupUser %>">
          <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" required minlength="4" autofocus>
          </div>
          <div class="form-group">
            <label>Confirm Password</label>
            <input type="password" name="confirm" required>
          </div>
          <div class="form-group checkbox-group">
            <label><input type="checkbox" name="remember" checked> Remember me</label>
          </div>
          <button type="submit" class="btn btn-primary">Set Password & Login</button>
        </form>
      <% } else { %>
        <h2>Login</h2>
        <% if (error) { %><div class="error"><%= error %></div><% } %>
        <form method="POST" action="/login">
          <div class="form-group">
            <label>Username</label>
            <input type="text" name="username" required autofocus>
          </div>
          <div class="form-group">
            <label>Password</label>
            <input type="password" name="password" required>
          </div>
          <div class="form-group checkbox-group">
            <label><input type="checkbox" name="remember" checked> Remember me</label>
          </div>
          <button type="submit" class="btn btn-primary">Login</button>
        </form>
      <% } %>
    </div>
  </main>
</body>
</html>

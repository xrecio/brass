<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Brass: Lancashire - Account</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <nav class="navbar">
    <a href="/lobby" class="nav-brand">Brass: Lancashire</a>
    <div class="nav-links">
      <a href="/lobby" class="nav-link">Lobby</a>
      <a href="/wiki" class="nav-link">Wiki</a>
      <a href="/profile" class="nav-link">Stats</a>
      <a href="/account" class="nav-user"><%= user.username %></a>
      <form method="POST" action="/logout" style="display:inline">
        <button type="submit" class="btn btn-sm">Logout</button>
      </form>
    </div>
  </nav>
  <main class="container">
    <h2>Account</h2>

    <!-- Account info -->
    <div class="stats-grid">
      <div class="stat-card">
        <div class="stat-value"><%= accountUser.username %></div>
        <div class="stat-label">Username</div>
      </div>
      <div class="stat-card">
        <div class="stat-value-sm"><%= new Date(accountUser.created_at).toLocaleDateString() %></div>
        <div class="stat-label">Member Since</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= activeGames %></div>
        <div class="stat-label">Active Games</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= finishedGames %></div>
        <div class="stat-label">Finished Games</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= stats.wins %></div>
        <div class="stat-label">Wins</div>
      </div>
      <div class="stat-card">
        <div class="stat-value-sm"><%= accountUser.last_login ? new Date(accountUser.last_login).toLocaleString() : 'Now' %></div>
        <div class="stat-label">Last Login</div>
      </div>
      <div class="stat-card">
        <div class="stat-value"><%= accountUser.login_count || 1 %></div>
        <div class="stat-label">Login Count</div>
      </div>
    </div>

    <!-- Change password -->
    <h3>Change Password</h3>
    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><%= success %></div>
    <% } %>
    <form method="POST" action="/account/change-password" class="create-form" style="max-width: 400px;">
      <div class="form-group">
        <label>Current Password</label>
        <input type="password" name="current_password" required>
      </div>
      <div class="form-group">
        <label>New Password</label>
        <input type="password" name="new_password" required>
      </div>
      <div class="form-group">
        <label>Confirm New Password</label>
        <input type="password" name="confirm_password" required>
      </div>
      <button type="submit" class="btn btn-primary">Change Password</button>
    </form>

    <!-- Game history -->
    <h3>Game History</h3>
    <% if (stats.gamesPlayed === 0) { %>
      <p class="muted">No completed games yet.</p>
    <% } else { %>
    <div class="game-history">
      <% for (const game of stats.recentGames) { %>
        <div class="history-card <%= game.won ? 'history-win' : '' %>">
          <div class="history-header">
            <strong><%= game.game_name %></strong>
            <span class="badge <%= game.won ? 'badge-active' : 'badge-finished' %>"><%= game.won ? 'WIN' : 'LOSS' %></span>
            <span class="muted"><%= game.myVP %> VP</span>
            <span class="muted"><%= new Date(game.finished_at).toLocaleDateString() %></span>
          </div>
          <div class="history-players">
            <% for (const p of game.players) { %>
              <span class="history-player <%= p.is_winner ? 'winner' : '' %>">
                <%= p.username %><%= p.is_bot ? ' (Bot)' : '' %>: <%= p.vp %> VP
                <%= p.is_winner ? ' *' : '' %>
              </span>
            <% } %>
          </div>
        </div>
      <% } %>
    </div>
    <% } %>
  </main>
</body>
</html>
